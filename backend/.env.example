# App Configuration
PROJECT_NAME="Bharath Delight Foods"
API_V1_STR="/api/v1"
SECRET_KEY="generate_a_secure_random_string_signature"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# MongoDB Connection Parameters
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/database?retryWrites=true&w=majority"
DATABASE_NAME="bharath_delight_foods"

# Caching & Queue Brokers
REDIS_URL="redis://localhost:6379/0"
UPI_ID="bharathdelightfoods@upi"

# Storage Services (Cloudflare R2)
R2_ENDPOINT_URL="https://account_id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="r2_access_key"
R2_SECRET_ACCESS_KEY="r2_secret_key"
R2_BUCKET_NAME="mbf-media-bucket"

# Storage Services (Cloudinary)
CLOUDINARY_CLOUD_NAME="cloudinary_cloud_name"
CLOUDINARY_API_KEY="cloudinary_api_key"
CLOUDINARY_API_SECRET="cloudinary_api_secret"

# Brevo Transactional Email Service
BREVO_API_KEY="your_brevo_api_key_here"
BREVO_SENDER_EMAIL="sender@bharathdelightfoods.in"
