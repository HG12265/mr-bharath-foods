# App Configuration
ENVIRONMENT=production
PROJECT_NAME="Bharath Delight Foods"
API_V1_STR=/api/v1
SECRET_KEY=replace-with-secure-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=11520
REFRESH_TOKEN_EXPIRE_DAYS=30

# MongoDB Connection Parameters
DATABASE_NAME=mr_bharath_foods
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/

# Caching & Queue Brokers
REDIS_URL=redis://localhost:6379/0
UPI_ID=replace-with-business-upi-id

# Frontend URL mapping
FRONTEND_ORIGIN=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com

# Storage Services (Cloudflare R2)
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Storage Services (Cloudinary)
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

# Brevo Transactional Email Service
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_SENDER_NAME="Bharath Delight Foods"
BREVO_SENDER_EMAIL=sender@example.com

# Admin contact for notifications (e.g. contact form inquiries)
ADMIN_EMAIL=admin@example.com
MEDIA_FOLDER_PREFIX=bharath-delight-foods